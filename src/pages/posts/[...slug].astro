---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', p => !p.data.draft);
  return posts.map(p => ({ params: { slug: p.slug }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={`${entry.data.title} — Kamal Nadh`} description={entry.data.description}>
  <Header />
  <main>
    <p class="back"><a href={`${base}posts/`}>← All posts</a></p>
    <article>
      <header class="post-head">
        <div class="meta">
          <time>{entry.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
          {entry.data.tags.map(t => <span class="tag">{t}</span>)}
        </div>
        <h1>{entry.data.heroEmoji ? `${entry.data.heroEmoji} ` : ''}{entry.data.title}</h1>
        <p class="lede">{entry.data.description}</p>
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  main { max-width: 680px; margin: 0 auto; padding: 2.5rem 1.25rem 2rem; }
  .back { margin-bottom: 2rem; }
  .back a { color: var(--fg-dim); font-size: .85rem; }
  .back a:hover { color: var(--accent); }
  .post-head { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
  .meta { display: flex; flex-wrap: wrap; gap: .75rem; align-items: center; color: var(--fg-dim); font-size: .82rem; margin-bottom: 1rem; }
  .tag { background: var(--bg-elev); border: 1px solid var(--border); padding: .1rem .55rem; border-radius: 999px; font-size: .7rem; }
  h1 { font-size: clamp(1.8rem, 4.5vw, 2.6rem); font-weight: 800; line-height: 1.15; margin-bottom: 1rem; }
  .lede { font-size: 1.1rem; color: var(--fg-dim); }
  .prose :global(h2) { font-family: 'Chivo'; font-size: 1.5rem; margin: 2.5rem 0 1rem; }
  .prose :global(h3) { font-family: 'Chivo'; font-size: 1.2rem; margin: 2rem 0 .75rem; color: var(--accent); }
  .prose :global(p) { margin: 0 0 1.25rem; color: var(--fg); }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.25rem 1.5rem; }
  .prose :global(li) { margin-bottom: .35rem; color: var(--fg); }
  .prose :global(strong) { color: var(--fg); }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: .92rem; }
  .prose :global(th), .prose :global(td) { padding: .6rem .75rem; border-bottom: 1px solid var(--border); text-align: left; }
  .prose :global(th) { background: var(--bg-elev); font-weight: 600; }
</style>
