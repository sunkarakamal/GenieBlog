---
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap">
    <div class="row">
      <span>© {year} Kamal Nadh Sunkara</span>
      <div class="links">
        <a href="https://www.linkedin.com/in/kamal-nadh-b1156b75/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/sunkarakamal" target="_blank" rel="noopener">GitHub</a>
        <a href="mailto:kamsun.uk@gmail.com">Email</a>
        <a href={`${import.meta.env.BASE_URL}rss.xml`}>RSS</a>
      </div>
    </div>
    <p class="tag">Built with Astro · deployed via GitHub Pages.</p>
  </div>
</footer>
<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: 5rem;
    padding: 2rem 1.25rem;
    color: var(--fg-dim);
    font-size: .85rem;
  }
  .wrap { max-width: 880px; margin: 0 auto; }
  .row {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 1rem;
  }
  .links { display: flex; gap: 1.25rem; }
  .links a { color: var(--fg-dim); }
  .links a:hover { color: var(--accent); }
  .tag { margin-top: 1rem; font-size: .75rem; opacity: .7; }
</style>
